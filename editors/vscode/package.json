{
  "name": "glyph-language",
  "displayName": "Glyph",
  "description": "Glyph language support: diagnostics, go-to-definition, semantic-token highlighting via the glyph LSP server.",
  "version": "0.1.0",
  "publisher": "glyph",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:glyph"
  ],
  "contributes": {
    "languages": [
      {
        "id": "glyph",
        "aliases": [
          "Glyph",
          "glyph"
        ],
        "extensions": [
          ".glyph",
          ".glyph.md"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Glyph",
      "properties": {
        "glyph.serverPath": {
          "type": "string",
          "default": "glyph",
          "description": "Path to the glyph CLI binary. The extension launches `<serverPath> lsp`."
        },
        "glyph.enableEffects": {
          "type": "boolean",
          "default": false,
          "description": "Enable the gated `effects:` subsystem (mirrors `glyph --enable-effects`)."
        },
        "glyph.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the JSON-RPC traffic between VS Code and the glyph language server."
        }
      }
    },
    "configurationDefaults": {
      "[glyph]": {
        "editor.semanticHighlighting.enabled": true
      },
      "editor.semanticTokenColorCustomizations": {
        "rules": {
            "glyphFlowString": "#FFAB40",
            "glyphFlowCall": {
              "foreground": "#FFCC66",
              "bold": true
            },
            "glyphBlockCall": {
              "foreground": "#82AAFF",
              "bold": true
            },
            "glyphContextString": {
              "foreground": "#7B8896",
              "italic": true
            },
            "glyphContextNameRef": {
              "foreground": "#89DDFF",
              "italic": true
            },
            "glyphSectionDescription": "#A0B9A0",
            "glyphSectionContext": "#D7BA7D",
            "glyphSectionConstraints": "#E5938A",
            "glyphSectionFlow": "#5CCFE6",
            "glyphInterpolation": {
              "foreground": "#FF6E9F",
              "bold": true
            },
            "function.declaration": {
              "foreground": "#FFCB6B",
              "bold": true
            },
            "method.declaration": {
              "foreground": "#82AAFF",
              "bold": true
            },
            "variable.declaration.readonly": {
              "foreground": "#FF8F73",
              "italic": true
            }
          },
          "[Default Light+]": {
            "rules": {
              "glyphFlowString": "#B45F06",
              "glyphFlowCall": {
                "foreground": "#9C6500",
                "bold": true
              },
              "glyphBlockCall": {
                "foreground": "#0066B8",
                "bold": true
              },
              "glyphContextString": {
                "foreground": "#6B7B8C",
                "italic": true
              },
              "glyphContextNameRef": {
                "foreground": "#0070AA",
                "italic": true
              },
              "glyphSectionDescription": "#3D7E3D",
              "glyphSectionContext": "#8A6D17",
              "glyphSectionConstraints": "#A02C2C",
              "glyphSectionFlow": "#0066B8",
              "glyphInterpolation": {
                "foreground": "#C7427A",
                "bold": true
              },
              "function.declaration": {
                "foreground": "#A06000",
                "bold": true
              },
              "method.declaration": {
                "foreground": "#0066B8",
                "bold": true
              },
              "variable.declaration.readonly": {
                "foreground": "#C03A60",
                "italic": true
              }
            }
          },
          "[Default Light Modern]": {
            "rules": {
              "glyphFlowString": "#B45F06",
              "glyphFlowCall": {
                "foreground": "#9C6500",
                "bold": true
              },
              "glyphBlockCall": {
                "foreground": "#0066B8",
                "bold": true
              },
              "glyphContextString": {
                "foreground": "#6B7B8C",
                "italic": true
              },
              "glyphContextNameRef": {
                "foreground": "#0070AA",
                "italic": true
              },
              "glyphSectionDescription": "#3D7E3D",
              "glyphSectionContext": "#8A6D17",
              "glyphSectionConstraints": "#A02C2C",
              "glyphSectionFlow": "#0066B8",
              "glyphInterpolation": {
                "foreground": "#C7427A",
                "bold": true
              },
              "function.declaration": {
                "foreground": "#A06000",
                "bold": true
              },
              "method.declaration": {
                "foreground": "#0066B8",
                "bold": true
              },
              "variable.declaration.readonly": {
                "foreground": "#C03A60",
                "italic": true
              }
            }
          },
          "[Light+ (default light)]": {
            "rules": {
              "glyphFlowString": "#B45F06",
              "glyphFlowCall": {
                "foreground": "#9C6500",
                "bold": true
              },
              "glyphBlockCall": {
                "foreground": "#0066B8",
                "bold": true
              },
              "glyphContextString": {
                "foreground": "#6B7B8C",
                "italic": true
              },
              "glyphContextNameRef": {
                "foreground": "#0070AA",
                "italic": true
              },
              "glyphSectionDescription": "#3D7E3D",
              "glyphSectionContext": "#8A6D17",
              "glyphSectionConstraints": "#A02C2C",
              "glyphSectionFlow": "#0066B8",
              "glyphInterpolation": {
                "foreground": "#C7427A",
                "bold": true
              },
              "function.declaration": {
                "foreground": "#A06000",
                "bold": true
              },
              "method.declaration": {
                "foreground": "#0066B8",
                "bold": true
              },
              "variable.declaration.readonly": {
                "foreground": "#C03A60",
                "italic": true
              }
            }
          },
          "[Light Modern]": {
            "rules": {
              "glyphFlowString": "#B45F06",
              "glyphFlowCall": {
                "foreground": "#9C6500",
                "bold": true
              },
              "glyphBlockCall": {
                "foreground": "#0066B8",
                "bold": true
              },
              "glyphContextString": {
                "foreground": "#6B7B8C",
                "italic": true
              },
              "glyphContextNameRef": {
                "foreground": "#0070AA",
                "italic": true
              },
              "glyphSectionDescription": "#3D7E3D",
              "glyphSectionContext": "#8A6D17",
              "glyphSectionConstraints": "#A02C2C",
              "glyphSectionFlow": "#0066B8",
              "glyphInterpolation": {
                "foreground": "#C7427A",
                "bold": true
              },
              "function.declaration": {
                "foreground": "#A06000",
                "bold": true
              },
              "method.declaration": {
                "foreground": "#0066B8",
                "bold": true
              },
              "variable.declaration.readonly": {
                "foreground": "#C03A60",
                "italic": true
              }
            }
          }
        }
      }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.4.5"
  }
}
