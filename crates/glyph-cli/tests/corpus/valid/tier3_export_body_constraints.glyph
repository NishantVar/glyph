export const preserve_behavior = "preserving existing behavior across refactors"
export const log_decisions = "logging each decision with a clear rationale"
export const monorepo_layout = "this codebase is a Rust workspace with multiple crates"

export block thorough_review(scope = "." <"directory to review">) -> Report
    description: "Perform a thorough code review of files under a given scope."

    must preserve_behavior
    require log_decisions
    context monorepo_layout
    context "background prose for the reviewer"

    flow:
        "Read the project structure in {scope} by listing all directories, subdirectories, and files in the project root and recursively scanning each nested folder to build a comprehensive understanding of the overall file tree layout and organization of the entire codebase."
        "Identify relevant source files and their relationships by tracing import statements, module declarations, dependency references, and cross-file function calls throughout the project to build a dependency graph that maps how each source file connects to and depends on other files."
        "Note any configuration files such as package manifests, build configuration files, environment variable definitions, continuous integration pipeline definitions, and deployment manifests that govern how the project is built, tested, and deployed."
        "Catalog all test suites including unit tests, integration tests, snapshot tests, and any test fixtures, test utilities, mock definitions, and stub implementations that support the testing infrastructure."
        return "Produce a comprehensive review report detailing the repository layout, key files, dependency relationships, and observed structural patterns across the entire project."
