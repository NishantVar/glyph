const complex_change_required = "the requested change requires regenerating multi-line prose that repair or prose-reshape originally authored, beyond a localised wording or value swap"

block recommend_full_compile()
    "Stop and recommend running `/glyph:compile` instead — incremental edit cannot regenerate prose."

skill predicate_const_single_arm()
    description: "Demonstrate single-arm pure-predicate const form."
    flow:
        if complex_change_required:
            recommend_full_compile()
