// decompile.glyph
//
// Skill that reverse-maps a compiled Glyph output (`.md`) back into Glyph
// source (`.glyph`). Pulls the language reference and authoring rules
// from sibling library files by per-const import.

import "../../skills/glyph/context.glyph" {
    glyph_overview,
    file_kinds,
    layout_rules,
    declarations,
    parameters,
    sub_sections,
    calls_and_control_flow,
    values,
    names_and_types,
    stdlib,
    library_files_and_prefs,
    compiled_output,
    pitfalls,
    worked_examples,
    quick_reference,
}

import "../../skills/glyph/constraints.glyph" {
    four_space_indentation,
    primitive_type_names_in_source,
    string_interpolation,
    hand_written_agent_prose,
    one_skill_per_skill_file,
    single_top_level_return,
    defaults_on_export_block_params,
    explicit_return_in_export_block,
    return_inside_branch_arms,
    slots_in_non_instruction_strings,
    novice_kernel_first,
    descriptive_domain_types,
    description_on_applies_blocks,
    review_of_repair_output,
    bare_text_in_flow_without_marker,
    overusing_must,
    deeply_nested_calls,
}

import "../../skills/glyph/passes.glyph" {
    factor_long_instructions_and_texts,
    sort_declarations,
    compile,
}

skill decompile(source_md, target)
    description: "Convert an existing compiled-form skill at `source_md` into a Glyph source file at `target`."

    context:
        glyph_overview
        file_kinds
        layout_rules
        declarations
        parameters
        sub_sections
        calls_and_control_flow
        values
        names_and_types
        stdlib
        library_files_and_prefs
        compiled_output
        pitfalls
        worked_examples
        quick_reference

    constraints:
        must four_space_indentation
        must avoid primitive_type_names_in_source
        must avoid string_interpolation
        must avoid hand_written_agent_prose
        must one_skill_per_skill_file
        must single_top_level_return
        must defaults_on_export_block_params
        must explicit_return_in_export_block
        must avoid return_inside_branch_arms
        must avoid slots_in_non_instruction_strings
        require decompile_by_semantic_content_not_shape
        require novice_kernel_first
        require descriptive_domain_types
        require description_on_applies_blocks
        require review_of_repair_output
        avoid bare_text_in_flow_without_marker
        avoid overusing_must
        avoid deeply_nested_calls

    flow:
        parse_compiled_skill(source_md)
        map_frontmatter_to_skill_header()
        classify_and_map_unplaced_content()
        map_context_section()
        map_constraints_section()
        recover_flow_from_steps()
        recover_conditionals_as_branches()
        write_initial_glyph_source(target)
        append_unmapped_section(target)
        factor_long_instructions_and_texts()
        sort_declarations()
        rename_source_md_with_old_prefix(source_md)
        compile_outcome = compile(target)
        if "there are no errors in compile_outcome":
            retry_unmapped_with_fresh_eyes(target)
            review_equivalence_via_subagent(source_md, target)
        else:
            surface_compile_errors(compile_outcome)
        return <"path to the produced .glyph file">

// ─────────────────────────────────────────────────────────────────────────────
// Conversion-procedure blocks — each block is one logical phase of reverse-
// mapping a compiled-form .md skill back into Glyph source.
// ─────────────────────────────────────────────────────────────────────────────

block parse_compiled_skill(source_md)
    "Read the file at {source_md}. Split the YAML frontmatter from the Markdown body. Within the body, locate the `## Parameters`, `### Context`, `### Steps`, and `### Constraints` sub-sections — note which are present and which are absent."

block map_frontmatter_to_skill_header()
    flow:
        "Use the frontmatter `name`, `description`, and parameter list (if present) to author the `skill <name>(params)` declaration line and its `description:` sub-section. Recover parameter names from the `## Parameters` section when the frontmatter does not list them. If the skill has a `## Variables` section (or similarly named block of user-editable knobs with defaults), map each variable to a skill parameter with its default value. Do not invent parameters that are not in the source."
        "When a `## Parameters` bullet carries description prose beyond name/default/required, attach that prose to the parameter as a per-param `<\"...\">` annotation. When the bullet names a domain noun (`branch`, `severity`, `plan`, `diagnosis`), add a `: PascalCaseType` annotation to the parameter and let the per-param description carry the meaning."
        "If two or more parameters in the source skill share the same domain-type label and description prose, hoist the prose into a top-level `type Foo = <\"...\">` decl and drop the per-param `<\"...\">` from each shared slot, keeping only `: Foo`. Do not introduce `type` decls for one-off types — they only pay off when reused."

block classify_and_map_unplaced_content()
    flow:
        context decompile_by_semantic_content_not_shape
        "Walk the compiled skill body section by section, including non-canonical sub-sections (custom `##` / `###` headers like `## Variables`, `## Workflow`, `## Cookbook`, `### Sending prompts to running sessions`, etc.) and any prose that has not yet been placed by frontmatter mapping. For each unit of unplaced prose, classify it semantically against the catalog of Glyph constructs before deciding it has no Glyph home."
        context classification_table
        "Apply the mapping that the classifier produces. For branches: define a new `block` whose body holds the entire branch arm — its steps, its context bullets, and its constraint bullets — and replace the original branch site in the parent flow with an `if PROCNAME.applies()` chain that dispatches by description. Set each new block's `description:` to the predicate prose of its arm so `.applies()` can match against runtime context, rolling any example trigger phrases into the description string."
        "For each context bullet and constraint bullet that came along inside an extracted arm, classify the wording. If it reads as a file-wide rule, hoist it to the parent skill's `context:` / `constraints:`. If it reads as scoped to this branch, leave it inside the procedure's own `context:` / `constraints:`. If the wording is ambiguous, ask the user."
        "Recurse on each newly created block: scan its body for nested unplaced content and re-apply this procedure. Stop when no body contains unplaced content."

block map_context_section()
    "Map each remaining top-level context bullet to a `context:` entry on the skill. Use inline strings at this stage; the factoring pass will promote them to `const` constants where appropriate."

block map_constraints_section()
    "Map each remaining top-level constraint bullet to a `constraints:` entry on the skill. Recover polarity from the bullet's leading verb (`Always` / `Must` / `Never` / `Avoid` / `Prefer` / `Consider`) and pick the matching marker (`require` / `must` / `must avoid` / `avoid`). Use inline strings; factoring will promote them later."

block recover_flow_from_steps()
    flow:
        "Map the remaining top-level numbered steps to instruction strings inside `flow:` in their original order. Branch sites already became `if PROCNAME.applies()` calls during extraction — leave them alone here. Steps that encode a conditional inline (an `If <predicate>:` clause with lettered sub-steps, optionally followed by an `Otherwise:` arm) are NOT extracted here either — preserve them verbatim as a placeholder so the next pass can convert them into Glyph branching statements."
        "If the final step describes what the skill produces, lift that into a top-level `return <\"description\">` statement at the end of `flow:` rather than restating it as another instruction."

block recover_conditionals_as_branches()
    flow:
        context decompile_by_semantic_content_not_shape
        "Walk the recovered `flow:` steps. For each step that encodes a conditional — an `If <predicate>:` clause with lettered sub-steps, optionally followed by an `Otherwise:` arm with its own sub-steps — break it down into a Glyph `if` / `else` branching statement inline in `flow:`, rather than leaving it as a single prose instruction. The clause's predicate becomes the `if` condition; each arm's lettered sub-steps become that arm's body, mapped to inline instructions, calls, or nested branches."
        "Pick the right condition form for each branch: `BLOCKNAME.applies()` when the predicate is the `description:` of a same-file block (its arm body lives in that block); a named string-`const` (`if predicate_name`) when the predicate stands on its own without a block body and recurs; an inline string literal (`if \"the predicate prose\"`) for a one-off predicate that does not warrant a const; otherwise the standard boolean / `==` / `!=` / `not` / `and` / `or` forms over bindings or call results."
        "Recurse on each arm body — nested `If <predicate>:` / `Otherwise:` structures inside an arm become nested Glyph `if` / `else` statements. Stop when no arm contains an unmapped conditional."
        "Never lift a conditional arm's contents into a top-level `return`. `return` is forbidden inside branch arms; if the original final step described what the skill produces, that step is handled by `recover_flow_from_steps`, not here."

block write_initial_glyph_source(target)
    "Write the assembled skill, blocks, and any extracted const constants to {target}. This is a verbose first draft — factoring and sorting will tidy it up next."

block rename_source_md_with_old_prefix(source_md)
    "Rename the file at {source_md} by prepending `old_` to its basename (e.g. `foo.md` becomes `old_foo.md` in the same directory). This preserves the original compiled skill so the upcoming Glyph compile of {target} does not overwrite it. If a file already exists at the destination, abort and surface the conflict to the user — do not overwrite."

block surface_compile_errors(compile_outcome)
    "Print every diagnostic in {compile_outcome} to the user verbatim and stop. The recompile of {target} failed, so equivalence review against the original is not meaningful — flag the decompile as incomplete and ask the user to fix the source before retrying."

block review_equivalence_via_subagent(source_md, target)
    flow:
        "Spawn a sub-agent and instruct it to load `.agents/skills/glyph/decompile_review.md` and follow that procedure, passing the renamed original (same directory as {source_md}, with `old_` prepended to its basename) as `original_md`, and the freshly recompiled `.md` produced from {target} (same directory as {target}, same stem with the `.glyph` extension replaced by `.md`) as `recompiled_md`. Print the resulting equivalence report to the user verbatim."

block append_unmapped_section(target)
    flow:
        context decompile_by_semantic_content_not_shape
        "Review the original compiled skill against everything mapped so far. UNMAPPED is a last resort: for each candidate unplaced item, re-run the classifier from `classify_and_map_unplaced_content` and confirm that every Glyph construct (block, if, flow step, parameter, constraint, context, description, return) has been considered and rejected before declaring the item UNMAPPED. Genuinely unmappable items are typically verbatim code-block snippets used as syntactic reference, frontmatter keys outside `name`/`description`/`effects`, or content with no actionable role."
        "If any unmapped content remains after that re-check, append it verbatim to the end of {target} under a `// UNMAPPED` header comment, with each item on its own `// `-prefixed line."
        "Report each unmapped item to the user as an error: name the original content, list which Glyph constructs you considered and rejected, and state why it has no Glyph equivalent."


block retry_unmapped_with_fresh_eyes(target)
    flow:
        context decompile_by_semantic_content_not_shape
        "Re-open {target} and scan for any remaining `// UNMAPPED` comments. For each unmapped item, run the classify-and-map procedure on it a second time with the fully-assembled file in front of you — content that resisted classification on the first pass sometimes places cleanly once the surrounding structure exists."
        "If the second pass produces a mapping, apply it and re-run the compile-via-subagent step on {target} to validate."
        "If the second pass still cannot place an item, leave it as UNMAPPED in the file and flag the entire decompile as **uncertain** when reporting back to the user. In the user-facing report: name each remaining UNMAPPED item, list which Glyph constructs you considered and rejected for it, tell the user explicitly that the round-trip is incomplete, and ask them to review before trusting the output."


// ─────────────────────────────────────────────────────────────────────────────
// Same-file consts — guiding principle and classifier reference table.
// ─────────────────────────────────────────────────────────────────────────────

const decompile_by_semantic_content_not_shape = "Decompile by semantic content, not by Markdown shape. Authors write meaning in whatever packaging they have on hand — your job is to recover the meaning into Glyph constructs (block, if, flow step, parameter, constraint, context, description, return). UNMAPPED is a last resort, not a fallback for unfamiliar Markdown shapes."

const classification_table = """
Classify each unplaced unit of prose by meaning, not by Markdown shape:

- "When X…" / "If you need Y…" / "For the case where…" / "Whenever Z…" prose, especially when it heads a sub-section → branch. Pick the minimal form: if the arm has a substantive body (multiple steps, its own context/constraints), define a `block` with `description:` set to the predicate and dispatch with `if PROCNAME.applies()`; if the arm is a single inline action and the predicate appears nowhere else, use an inline string predicate (`if "the predicate prose": single_action()`); if the predicate prose recurs across arms or files, factor it into a `const some_predicate = "the prose"` and dispatch with `if some_predicate`. Reach for `.applies()` only when the predicate ships bundled with a block body.
- A sequence of imperative actions under any header (numbered list, bulleted list, or ordered prose) → `block` with a `flow:` body. Call it from the parent flow.
- "Always X" / "Must X" / "Never Y" / "Avoid Y" / "Prefer Z" / "Consider Z" → constraint marker. Pick polarity from the verb: `Always` / `Must` → `must` or `require`; `Never` / `Avoid` → `must avoid` or `avoid`; `Prefer` / `Consider` → `require` (soft).
- "Note that…" / "Assume…" / informational background that does not direct action → `context:` entry on the enclosing skill or block.
- A `## Variables` / `## Configuration` / `## Settings` block of user-editable knobs with defaults → skill parameters with defaults. The default literal becomes the parameter default.
- "EXAMPLES: …" / "e.g. X, Y, Z" tied to a triggered behavior → fold into the trigger block's `description:` string. Do not create a separate construct.
- "This produces / returns / outputs X" at the end of a flow → `return <\"X\">` (output target) or `-> DomainType` if a domain noun is named.
- An import from another skill or shared library → `import` declaration at the top of the file.
- Truly UNMAPPED only after every classifier above has been considered and rejected: verbatim code-block snippets used as syntactic reference, frontmatter keys outside `name` / `description` / `effects`, and content with no actionable role.
"""
