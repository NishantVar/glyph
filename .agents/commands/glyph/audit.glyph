// audit.glyph — /glyph:audit
//
// Runs semantic checks on a Glyph source file or directory of Glyph
// sources, surfacing issues that don't break compilation but suggest
// the skill may not behave as intended. Currently runs the constraint-
// conflict scan; more semantic checks may be added over time.

skill audit(source_path)
    description: "Runs semantic checks (currently constraint-conflict scanning) against each declaration's resolved constraint set and surfaces any contradictions or tensions to the author."

    flow:
        scan_constraint_conflicts(source_path)
        return <"a human-readable report listing every contradiction (fatal) and tension (warning) found across the audited sources, grouped by source file and declaration">

block scan_constraint_conflicts(source_path)
    flow:
        "Enumerate every `.glyph` source under {source_path}: a single file when {source_path} is a `.glyph` file, or every `*.glyph` recursively under {source_path} when it is a directory. For each source, derive `<stem>` by stripping the trailing `.glyph` from the basename and look for the IR sidecar at `<dir>/<stem>.ir.json`."
        "If any source is missing its IR sidecar, stop and tell the user to run `/glyph:compile {source_path}` first — `/glyph:audit` reads the resolved IR rather than re-parsing the source, so it requires a prior successful compile."
        "Across every IR sidecar, enumerate every declaration whose `constraints:` set has 2 or more entries. Skip declarations with 0 or 1 constraints without an LLM call."
        "For each such declaration, load `.agents/skills/glyph/semantic_validation.md` and follow its procedure, passing the declaration's resolved constraint set as input."
        "Aggregate the returned JSON conflict reports across every audited declaration. Surface a single human-readable report grouped by source file and declaration: each `contradiction` is reported as a fatal finding, each `tension` is reported as a warning. The contract is that the author edits the source and recompiles — `/glyph:audit` never rewrites the source or the compiled `.md`."
        "Exit non-zero if any `contradiction` was reported; exit zero otherwise (tensions are warnings, not failures)."
