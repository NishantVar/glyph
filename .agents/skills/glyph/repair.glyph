// repair.glyph — Glyph repair Phase 3b
//
// Independently invokable LLM repair skill. Loaded by /glyph:compile
// when the compiler exits 2 with repairable diagnostics on a single
// source file. One invocation rewrites that one source file in place;
// up to 3 iterations per file across the compile-with-repair loop.

skill repair(source_path, diagnostics) -> RewrittenSource
    description: "Use during a /glyph:compile run when the compiler has exited 2 with repairable diagnostics on a single Glyph source file. Read the source plus its NDJSON diagnostics, apply each diagnostic's rewrite pattern, and write the rewritten Glyph source file back to source_path."

    require diagnostic_driven_rewrites_only
    must parseable_glyph_output
    must avoid regenerating_already_resolved_names

    context:
        invocation_shape_is_one_file_with_its_diagnostics
        compound_names_stay_atomic
        invalid_output_is_discarded_without_retry

    flow:
        repair_operator_in_expression()
        repair_param_slot_in_non_instruction_string()
        materialize_undefined_name_as_const()
        materialize_undefined_call_as_block()
        attach_explicit_role_marker()
        append_explicit_return()
        infer_and_attach_return_type()
        extract_nested_branch_into_block()
        synthesize_skill_description()
        synthesize_same_file_block_description()
        surface_imported_undescribed_block_as_non_repairable()
        skip_already_resolved_names()
        repair_other_unambiguous_parse_or_analyze_error()
        return <"the full rewritten Glyph source file as a single text blob">

block repair_operator_in_expression()
    "For each `G::parse::operator-in-expression` diagnostic, rewrite the offending `x + y` form as a `combine(x, y)` call, or fold the operands into a single inline instruction string."

block repair_param_slot_in_non_instruction_string()
    "For each `G::parse::param-slot-in-non-instruction-string` diagnostic, strip the `{...}` braces, or move the slot into an instruction-bearing string."

block materialize_undefined_name_as_const()
    "For each `G::analyze::undefined-name` diagnostic, append `generated const <name> = \"<one sentence>\"` after every non-generated declaration in the file."

block materialize_undefined_call_as_block()
    "For each `G::analyze::undefined-call` diagnostic, append `generated block <name>(<inferred-params>)` with a single-string body, after every non-generated declaration."

block attach_explicit_role_marker()
    "For each `G::analyze::ambiguous-role` diagnostic, add an explicit role marker (`require` / `avoid` / `must` / `context`) to the offending entry, or convert it into an instruction string or a call."

block append_explicit_return()
    "For each `G::analyze::missing-return` diagnostic, append `return <expr>` as the final statement of the relevant `flow:`. Use `return none` when there is no meaningful value to return."

block infer_and_attach_return_type()
    "For each `G::analyze::export-missing-return-type` diagnostic, infer a named domain type from the returned value (never a primitive name) and add ` -> DomainType` to the export block's header."

block extract_nested_branch_into_block()
    "For each `G::analyze::nested-branch` diagnostic, extract the inner branch into a `generated block` and replace it with a call passing captured outer-scope bindings."

block synthesize_skill_description()
    "For each `G::analyze::missing-description` diagnostic on a skill, generate a single-line `description:` phrased as a trigger condition the consuming agent can match on."

block synthesize_same_file_block_description()
    "For each `G::analyze::applies-on-undescribed-block` diagnostic where the referenced block is in the same file, generate a trigger-shaped `description:` for that block."

block surface_imported_undescribed_block_as_non_repairable()
    "For an `G::analyze::applies-on-undescribed-block` diagnostic where the referenced block is imported from another file, leave it alone — the diagnostic is non-repairable and the imported file must not be edited."

block skip_already_resolved_names()
    "Skip any unresolved-name or unresolved-call diagnostic whose name already resolves via existing imports, stdlib entries, or other local declarations. Idempotence requires that already-resolved names are never regenerated."

block repair_other_unambiguous_parse_or_analyze_error()
    "For any repairable diagnostic whose code is not handled by the rules above, read the source span identified by the diagnostic and apply the minimal syntactic fix that resolves it — only when the fix is unambiguous from the source context. When the fix is ambiguous or multiple reasonable rewrites exist, leave the diagnostic alone so the compile pipeline can surface it to the author."

const diagnostic_driven_rewrites_only = "Apply only rewrites that match a diagnostic in the input set. Do not introduce edits that no diagnostic asked for."

const parseable_glyph_output = "Produce a Glyph source file that parses successfully under Phase 1 of the compiler. If it does not, the failed rewrite is discarded and the agent aborts without retry, surfacing `G::repair::output-invalid`."

const regenerating_already_resolved_names = "regenerate a `generated const` or `generated block` whose name already resolves via an existing import, the standard library, or another local declaration."

const invocation_shape_is_one_file_with_its_diagnostics = "The LLM receives one Glyph source file plus its full set of repairable diagnostics in a single prompt, and returns one rewritten source file. One LLM call per file per iteration; up to 3 iterations per file."

const compound_names_stay_atomic = "A compound name such as `avoid_unrelated_edits` (when unresolved) must be materialized as a single `generated const` under the full compound name, with polarity baked into the body text. Never split it into a marker and a base name."

const invalid_output_is_discarded_without_retry = "When the rewritten output fails Phase 1 parsing, the agent does not retry. The failed rewrite is captured for inspection and the run aborts with `G::repair::output-invalid`."
