{
  "permissions": {
    "allow": [
      "Bash(cargo *)",
      "Bash(tree-sitter *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Read(**/*.toml)",
      "Read(**/*.md)",
      "Read(**/*.glyph)",
      "Read(**/*.snap)",
      "Read(**/*.json)",
      "Read(**/*.lock)",
      "Read(**/*.yaml)",
      "Read(**/*.yml)",
      "Read(**/*.txt)",
      "Edit(**/*.toml)",
      "Edit(**/*.md)",
      "Edit(**/*.glyph)",
      "Edit(**/*.snap)",
      "Edit(**/*.json)",
      "Edit(**/*.yaml)",
      "Edit(**/*.yml)",
      "Edit(**/*.txt)",
      "Write(**/*.toml)",
      "Write(**/*.md)",
      "Write(**/*.glyph)",
      "Write(**/*.snap)",
      "Write(**/*.json)",
      "Write(**/*.yaml)",
      "Write(**/*.yml)",
      "Write(**/*.txt)"
    ],
    "deny": [
      "Read(**/*.rs)",
      "Edit(**/*.rs)",
      "Write(**/*.rs)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/implementer-gate.sh"
          }
        ]
      }
    ]
  }
}
